{
  "name": "demo-energy",
  "version": "1.12.3",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "docker:rebuild": "docker rm -f energy-database || true && (docker compose down || docker-compose down) && (docker compose up --build -d || docker-compose up --build -d)",
    "docker:reset": "(docker compose down -v || docker-compose down -v) && (docker compose up --build -d || docker-compose up --build -d)",
    "docker:fresh": "(docker compose down -v || docker-compose down -v) && docker system prune -f --volumes && (docker compose build --no-cache || docker-compose build --no-cache) && (docker compose up -d || docker-compose up -d)",
    "docker:logs": "docker compose logs -f || docker-compose logs -f",
    "docker:ps": "docker compose ps || docker-compose ps",
    "docker:db": "docker exec -it energy-database psql -U energy -d energy_customer"
  },
  "dependencies": {
    "@hcl-cdp-ta/hclcdp-web-sdk-react": "^1.1.3",
    "@hcl-cdp-ta/interact-sdk": "^2.7.1",
