# Multi-tenant Database Configuration
# Copy this to .env and customize for your deployment

# Industry vertical - determines database name
INDUSTRY_VERTICAL=energy

# Industry-specific database connection
DATABASE_URL=postgresql://multitenant_user:multitenant_password@shared-postgres-multitenant:5432/energy

# For external access (connecting from host machine during development):
# DATABASE_URL=postgresql://multitenant_user:multitenant_password@localhost:5432/energy

# Application settings
DEPLOY_IMAGE_NAME=energy-app
DEPLOY_CONTAINER_PREFIX=energy
DEPLOY_SITE_PORT=3005

# CDP Settings
NEXT_PUBLIC_CDP_WRITEKEY=your_cdp_writekey
NEXT_PUBLIC_CDP_ENDPOINT=your_cdp_endpoint
NEXT_PUBLIC_DISCOVER_DEFAULT_SCRIPT=your_discover_script
NEXT_PUBLIC_INTERACT_ENDPOINT=your_interact_endpoint
NEXT_PUBLIC_INTERACT_CHANNEL_NAME="Energy Web Site"
NEXT_PUBLIC_INTERACTION_POINT=ipHomePage
NEXT_PUBLIC_GA_MEASUREMENT_ID=your_ga_id

# Google Maps API Key (for address lookup on plans page)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
